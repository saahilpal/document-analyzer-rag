# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
TRUST_PROXY=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_REQUEST_BODY_SIZE_BYTES=2097152

# Database
DB_PATH=data/studyrag.sqlite

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_LOCK_MS=900000
AUTH_LOGIN_MAX_FAILURES=6

# Upload and Parsing Limits
MAX_UPLOAD_FILE_SIZE_BYTES=31457280
MAX_DOCS_PER_SESSION=5
MAX_PDF_PAGES=150
MAX_CHUNKS_PER_QUERY=2000
MAX_EXTRACTED_TEXT_LENGTH=2000000

# Gemini (chat generation only)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# RAG Tuning
RAG_TOP_K=5
RAG_CANDIDATE_PAGE_SIZE=400
RAG_HISTORY_LIMIT=12
RAG_RESPONSE_STYLE=structured
RAG_TOKEN_TO_CHAR_RATIO=4
RAG_CHUNK_TOKENS=1000
RAG_CHUNK_OVERLAP_TOKENS=200

# Local Embeddings (Transformers.js + ONNX)
LOCAL_EMBEDDING_BATCH_SIZE=24
LOCAL_EMBEDDING_BATCH_SIZE_MIN=8
LOCAL_EMBEDDING_BATCH_SIZE_MAX=64

# Cleanup Worker
CLEANUP_INTERVAL_MS=900000
CLEANUP_COMPLETED_JOB_TTL_HOURS=24
CLEANUP_FAILED_JOB_TTL_HOURS=72
CLEANUP_TEMP_FILE_TTL_HOURS=6

# SMTP (OTP + security emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="DocAnalyzer <noreply@example.com>"
APP_NAME=DocAnalyzer

# Optional migration bootstrap admin
DEFAULT_ADMIN_EMAIL=admin@local
DEFAULT_ADMIN_NAME=Default Admin
DEFAULT_ADMIN_PASSWORD=
